<% if params[:deleted] %>
  <div class="toast toast-ok">Collection removed from database.</div>
<% end %>
<div class="page-header">
  <div>
    <h1>Collections</h1>
    <p class="page-sub"><%= @collections.length %> folder<%= @collections.length == 1 ? '' : 's' %> scanned</p>
  </div>
  <div style="display:flex; align-items:center; gap:8px;">
    <% other_sort = @sort_order == 'asc' ? 'desc' : 'asc' %>
    <a href="<%= url_collections(sort: other_sort) %>" class="col-info-edit" title="Toggle sort order">
      <%= @sort_order == 'desc' ? '↓ Newest first' : '↑ Oldest first' %>
    </a>
  </div>
</div>

<% if @unlinked_colorized_count.to_i > 0 || @unset_colorized_count.to_i > 0 %>
<div class="xref-alert">
  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
  <span>
    <% if @unlinked_colorized_count.to_i > 0 %>
      <strong><%= @unlinked_colorized_count %></strong> colorized image<%= @unlinked_colorized_count == 1 ? '' : 's' %> not yet linked to a grey primary.
    <% end %>
    <% if @unset_colorized_count.to_i > 0 %>
      <strong><%= @unset_colorized_count %></strong> image<%= @unset_colorized_count == 1 ? '' : 's' %> with unknown colorized status.
    <% end %>
  </span>
  <div style="display:flex; gap:6px; margin-left:auto;">
    <% if @unlinked_colorized_count.to_i > 0 %>
      <a href="/catalog?show_all=1&colorized=true" class="xref-alert-link">Link colorized →</a>
    <% end %>
    <% if @unset_colorized_count.to_i > 0 %>
      <a href="/bulk?field=colorized" class="xref-alert-link">Set color status →</a>
    <% end %>
  </div>
</div>
<% end %>

<div class="col-year-bar">
  <a href="<%= url_collections(year: '') %>"
     class="col-year-btn <%= @year_filter.empty? ? 'col-year-active' : '' %>">All years</a>
  <% @years.each do |yr| %>
    <a href="<%= url_collections(year: yr) %>"
       class="col-year-btn <%= @year_filter == yr ? 'col-year-active' : '' %>"><%= yr %></a>
  <% end %>
</div>

<div class="col-filter-bar">
  <% filters = [
    ['', 'All'],
    ['unprinted',         '🖨 0 printed'],
    ['unpainted',         '🎨 0 painted'],
    ['partially_printed', '🖨 Partial'],
  ] %>
  <% filters.each do |val, label| %>
    <a href="<%= url_collections(filter: val) %>"
       class="col-filter-btn <%= @filter == val ? 'col-filter-active' : '' %>">
      <%= label %>
    </a>
  <% end %>
  <span class="col-filter-count"><%= @collections.length %> collection<%= @collections.length == 1 ? '' : 's' %></span>
</div>

<% if @collections.empty? %>
  <div class="empty-state">No collections match this filter.</div>
<% else %>

<% saved_id = params[:saved].to_i %>

<div class="collections-grid">
  <% @collections.each do |col| %>
    <% is_saved = saved_id > 0 && col[:id] == saved_id %>
    <div class="collection-card <%= is_saved ? 'collection-card-saved' : '' %>"
         id="col-<%= col[:id] %>">
      <% preview = @previews[col[:id]] %>
      <% col_link = "/collection/#{col[:id]}" %>
      <% if preview %>
        <a href="<%= col_link %>" class="col-preview-wrap">
          <img src="/image_file/<%= preview[:id] %>"
               alt="<%= preview[:filename] %>"
               loading="lazy"
               class="col-preview-img">
          <span class="col-preview-count"><%= @counts[col[:id]] || 0 %> images</span>
        </a>
      <% end %>

      <form action="/collections/<%= col[:id] %>" method="post" class="col-form">

        <div class="col-card-header">
          <div class="col-card-meta">
            <% if col[:release_month] %>
              <span class="col-month"><%= col[:release_month] %></span>
            <% end %>
            <% unless @previews[col[:id]] %>
              <span class="col-count"><%= @counts[col[:id]] || 0 %> images</span>
            <% end %>
            <% if is_saved %>
              <span class="col-saved-badge">✓ saved</span>
            <% end %>
          </div>
          <button type="submit" class="btn-save col-save-btn" title="Save">✓</button>
        </div>

        <%# Always show folder name so unnamed cards are identifiable %>
        <div class="col-folder-label">
          <svg viewBox="0 0 24 24" class="col-folder-icon"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <code><%= File.basename(col[:folder_path]) %></code>
        </div>

        <div class="form-group">
          <label>Collection Name</label>
          <div class="col-name-row">
            <input type="text" name="name" value="<%= col[:name] %>"
                   placeholder="e.g. ASH NOMADS"
                   class="col-name-input <%= col[:name].to_s.empty? ? 'unset' : '' %>"
                   id="col-name-<%= col[:id] %>"
                   oninput="this.value = this.value.toUpperCase()">
            <button type="button"
                    class="btn-detect"
                    onclick="detectName(<%= col[:id] %>)"
                    title="Run OCR on this folder to detect name">
              <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              Detect
            </button>
          </div>
          <div class="col-detect-result" id="col-detect-<%= col[:id] %>"></div>
        </div>

        <div class="form-group">
          <label>Full Path</label>
          <code class="col-folder"><%= col[:folder_path] %></code>
        </div>

        <div class="form-group">
          <label>Notes</label>
          <input type="text" name="notes" value="<%= col[:notes] %>" placeholder="Optional notes">
        </div>

        <% s = @stats[col[:id]] || {} %>
        <div class="col-stats-row">
          <span class="col-stat" title="Total images"><span class="col-stat-icon">⬡</span> <%= s[:total] || 0 %></span>
          <span class="col-stat <%= (s[:printed] || 0) == 0 ? 'col-stat-zero' : '' %>" title="Printed"><span class="col-stat-icon">🖨</span> <%= s[:printed] || 0 %></span>
          <span class="col-stat <%= (s[:painted] || 0) == 0 ? 'col-stat-zero' : '' %>" title="Painted"><span class="col-stat-icon">🎨</span> <%= s[:painted] || 0 %></span>
          <% if (s[:unprinted] || 0) > 0 %>
            <a href="/collection/<%= col[:id] %>?f_unprinted=1"
               class="col-stat col-stat-warn col-stat-link" title="View unprinted images in catalog">
              ⚠ <%= s[:unprinted] %> unprinted
            </a>
          <% end %>
          <% if (s[:unpainted] || 0) > 0 && (s[:painted] || 0) > 0 %>
            <a href="/collection/<%= col[:id] %>?f_unpainted=1"
               class="col-stat col-stat-warn col-stat-link" title="View unpainted images in catalog">
              ⚠ <%= s[:unpainted] %> unpainted
            </a>
          <% end %>
        </div>

        <div class="col-card-footer">
          <a href="/collection/<%= col[:id] %>" class="col-browse-link">
            Browse images →
          </a>
          <% mmf_url = url_mmf_search(col[:release_month]) %>
          <% if mmf_url %>
            <a href="<%= mmf_url %>" class="col-mmf-link" target="_blank"
               title="Search MyMiniFactory for unit9 <%= col[:release_month] %>">
              MMF
            </a>
          <% end %>
          <% pdf = file_collection_pdf_path(col[:folder_path]) %>
          <% if pdf %>
            <a href="<%= url_pdf(col[:id]) %>" class="col-pdf-link" target="_blank" title="<%= col[:folder_path] %>.pdf">
              <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Open PDF
            </a>
          <% else %>
            <span class="col-pdf-missing" title="<%= col[:folder_path] %>.pdf">
              <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              No PDF found
            </span>
          <% end %>
          <%
            _del_name = col[:name].to_s.empty? ? File.basename(col[:folder_path]) : col[:name]
            _del_msg  = "Delete #{_del_name.gsub('"', '&quot;')} from the database?\nFiles stay on disk."
            _is_empty = (@counts[col[:id]] || 0) == 0
          %>
          <form action="/collections/<%= col[:id] %>/delete" method="post" style="display:inline;"
                onsubmit="return confirm(<%= _del_msg.to_json %>)">
            <% if _is_empty %>
              <button type="submit" class="col-delete-btn col-delete-btn-empty" title="Delete empty collection">🗑 Delete empty</button>
            <% else %>
              <button type="submit" class="col-delete-btn" title="Delete this collection from database">🗑</button>
            <% end %>
          </form>
        </div>
      </form>
    </div>
  <% end %>

  <%# ── Stub cards for months with no collection yet ── %>
  <% (@stubs || []).each do |ym| %>
    <% year, mon = ym.split('-').map(&:to_i) %>
    <% mon_name = MONTH_NAMES[mon - 1].capitalize rescue ym %>
    <div class="collection-card col-stub" id="stub-<%= ym %>">
      <div class="col-stub-header">
        <span class="col-stub-month"><%= mon_name %> <%= year %></span>
        <span class="col-stub-badge">not scanned</span>
        <button type="button" class="col-stub-dismiss" onclick="dismissStub('<%= ym %>')" title="Hide this stub">✕</button>
      </div>
      <div class="col-stub-actions">
        <a href="<%= url_mmf_search(ym) %>" class="col-stub-mmf" target="_blank" title="Search MMF for <%= mon_name %> <%= year %>">
          <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          MMF →
        </a>
      </div>
    </div>
  <% end %>
</div>

<% end %>

<script>
function dismissStub(ym) {
  var el = document.getElementById('stub-' + ym);
  if (el) {
    el.style.transition = 'opacity 0.3s';
    el.style.opacity = '0';
    setTimeout(function() { el.remove(); }, 300);
  }
  try {
    var dismissed = JSON.parse(localStorage.getItem('mf_dismissed_stubs') || '[]');
    if (!dismissed.includes(ym)) dismissed.push(ym);
    localStorage.setItem('mf_dismissed_stubs', JSON.stringify(dismissed));
  } catch(e) {}
}

document.addEventListener('DOMContentLoaded', function() {
  try {
    var dismissed = JSON.parse(localStorage.getItem('mf_dismissed_stubs') || '[]');
    dismissed.forEach(function(ym) {
      var el = document.getElementById('stub-' + ym);
      if (el) el.remove();
    });
  } catch(e) {}
});
</script>

<div id="lightbox" class="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <img id="lightbox-img" src="" alt="Preview">
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Dirty-state save button
  document.querySelectorAll('.col-form').forEach(form => {
    const inputs  = form.querySelectorAll('input[type="text"]');
    const saveBtn = form.querySelector('.col-save-btn');
    if (!saveBtn) return;
    const originals = {};
    inputs.forEach(inp => { originals[inp.name] = inp.value; });
    inputs.forEach(inp => {
      inp.addEventListener('input', () => {
        const dirty = Array.from(inputs).some(i => i.value !== originals[i.name]);
        saveBtn.classList.toggle('col-save-dirty', dirty);
      });
    });
  });

  // Scroll saved card into view after a save
  const saved = document.querySelector('.collection-card-saved');
  if (saved) {
    saved.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => saved.classList.remove('collection-card-saved'), 3000);
  }

  // Highlight card targeted by anchor (e.g. from catalog "edit collection" link)
  const anchor = window.location.hash;
  if (anchor && !saved) {
    const target = document.querySelector(anchor);
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'center' });
      target.classList.add('collection-card-focused');
      setTimeout(() => target.classList.remove('collection-card-focused'), 3000);
    }
  }

  // OCR detect name
  window.detectName = async function(id) {
    const btn    = document.querySelector(`#col-${id} .btn-detect`);
    const input  = document.getElementById(`col-name-${id}`);
    const result = document.getElementById(`col-detect-${id}`);
    if (!btn || !input || !result) return;

    btn.disabled = true;
    btn.textContent = 'Scanning…';
    result.innerHTML = '';

    try {
      const res  = await fetch(`/collections/${id}/detect_name`, { method: 'POST' });
      const data = await res.json();

      if (!res.ok) {
        result.innerHTML = `<span class="detect-error">✕ ${data.error}</span>`;
        return;
      }

      const mini = data.suggested_name;
      const col  = data.collection_name;

      let html = '';
      if (mini) html += `<span class="detect-chip detect-mini" onclick="useDetected('col-name-${id}', '${mini.replace(/'/g,"\'")}', this)">✦ ${mini}</span>`;
      if (col)  html += `<span class="detect-chip detect-col"  onclick="useDetected('col-name-${id}', '${col.replace(/'/g,"\'")}', this)">⊕ ${col}</span>`;
      if (!html) html = '<span class="detect-error">No text found</span>';

      result.innerHTML = '<span class="detect-label">Click to use:</span> ' + html;

    } catch(e) {
      result.innerHTML = `<span class="detect-error">✕ Request failed</span>`;
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg> Detect';
    }
  };

  window.useDetected = function(inputId, value, chip) {
    const input = document.getElementById(inputId);
    if (!input) return;
    input.value = value;
    input.classList.remove('unset');
    input.dispatchEvent(new Event('input'));
    // Mark all chips inactive, highlight chosen
    chip.closest('.col-detect-result').querySelectorAll('.detect-chip').forEach(c => c.classList.remove('detect-chip-active'));
    chip.classList.add('detect-chip-active');
  };
});
</script>
