<div class="page-header">
  <div>
    <h1>Search</h1>
    <p class="page-sub">Fuzzy match across all fields · scored by relevance</p>
  </div>
</div>

<form action="/search" method="get" class="search-form">
  <div class="search-bar">
    <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input type="text" name="q" value="<%= @params['q'] %>" placeholder="Search names, species, weapons… fuzzy matching included" class="search-main" autofocus>
    <button type="submit" class="btn-primary">Search</button>
  </div>

  <details class="field-filters" <%= (@params.any? { |k,v| %w[mini_name species gender weapons stance mini_size colorized].include?(k) && v.to_s.strip.length > 0 }) ? 'open' : '' %>>
    <summary>Field Filters</summary>
    <div class="filter-grid">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="mini_name" value="<%= @params['mini_name'] %>" placeholder="e.g. Zara">
      </div>
      <div class="form-group">
        <label>Species</label>
        <input type="text" name="species" id="search-species" value="<%= @params['species'] %>" placeholder="e.g. Elf" autocomplete="off">
        <% if @top_species&.any? %>
          <div class="species-quickpick" style="margin-top:4px;">
            <% @top_species.each do |sp| %>
              <button type="button"
                      class="btn-quickpick <%= @params['species'].to_s.upcase == sp ? 'btn-quickpick-active' : '' %>"
                      data-target="search-species" data-value="<%= sp %>"
                      onclick="searchQuickpick(this)"><%= sp %></button>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="form-group">
        <label>Gender</label>
        <select name="gender">
          <option value="">Any</option>
          <% ['M','F','NA'].each do |g| %>
            <option value="<%= g %>" <%= @params['gender'] == g ? 'selected' : '' %>><%= g %></option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <label>Weapons</label>
        <input type="text" name="weapons" id="search-weapons" value="<%= @params['weapons'] %>" placeholder="e.g. Sword" autocomplete="off">
      </div>
      <div class="filter-group">
        <label>Armour</label>
        <input type="text" name="armour" id="search-armour" value="<%= @params['armour'] %>" placeholder="e.g. Heavy" autocomplete="off">
        <% if @top_weapons&.any? %>
          <div class="species-quickpick" style="margin-top:4px;">
            <% @top_weapons.each do |wp| %>
              <button type="button"
                      class="btn-quickpick <%= @params['weapons'].to_s.upcase == wp ? 'btn-quickpick-active' : '' %>"
                      data-target="search-weapons" data-value="<%= wp %>"
                      onclick="searchQuickpick(this)"><%= wp %></button>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="form-group">
        <label>Stance</label>
        <input type="text" name="stance" id="search-stance" value="<%= @params['stance'] %>" placeholder="e.g. Combat" autocomplete="off">
        <% if @top_stance&.any? %>
          <div class="species-quickpick" style="margin-top:4px;">
            <% @top_stance.each do |st| %>
              <button type="button"
                      class="btn-quickpick <%= @params['stance'].to_s.upcase == st ? 'btn-quickpick-active' : '' %>"
                      data-target="search-stance" data-value="<%= st %>"
                      onclick="searchQuickpick(this)"><%= st %></button>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="form-group">
        <label>Size</label>
        <select name="mini_size">
          <option value="">Any</option>
          <% ['S','M','L'].each do |s| %>
            <option value="<%= s %>" <%= @params['mini_size'] == s ? 'selected' : '' %>><%= s %></option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <label># Minis</label>
        <select name="mini_count">
          <option value="">Any</option>
          <% ['1','2','3','4+'].each do |n| %>
            <option value="<%= n %>" <%= @params['mini_count'] == n ? 'selected' : '' %>><%= n %></option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <label>Colorized</label>
        <select name="colorized">
          <option value=""       <%= @params['colorized'].to_s.empty?        ? 'selected' : '' %>>Any</option>
          <option value="true"   <%= @params['colorized'] == 'true'          ? 'selected' : '' %>>🎨 Colorized</option>
          <option value="false"  <%= @params['colorized'] == 'false'         ? 'selected' : '' %>>⬜ Grey</option>
          <option value="unknown"<%= @params['colorized'] == 'unknown'       ? 'selected' : '' %>>❓ Unknown</option>
        </select>
      </div>
    </div>
  </details>
</form>

<% if @query_made %>
  <div class="results-header">
    <span class="results-count" id="results-count"><%= @results.length %> result<%= @results.length == 1 ? '' : 's' %></span>
    <div class="score-filter">
      <label for="score-slider">Min score:</label>
      <input type="range" id="score-slider" min="0" max="5" step="0.1" value="0.9"
             oninput="filterByScore(this.value)">
      <span id="score-value">0.9</span>
    </div>
    <span class="results-sorted">sorted by score</span>
  </div>

  <% if @results.empty? %>
    <div class="empty-state">No matches found. Try broader terms or check spelling.</div>
  <% else %>
    <div class="results-grid">
      <% @results.each do |result| %>
        <% img = result[:row]; score = result[:score]; hl = result[:highlights] %>
        <div class="result-card" data-score="<%= score %>">
          <div class="result-image-wrap" onclick="openLightbox('/image_file/<%= img[:id] %>')">
            <img src="/image_file/<%= img[:id] %>" alt="<%= img[:filename] %>" loading="lazy" class="result-image">
            <div class="score-badge"><%= score %></div>
          </div>

          <div class="result-body">
            <div class="result-file">
              <% _sc = @collections[img[:collection_id]] %>
              <% _col_name = _sc ? (_sc[:name].to_s.empty? ? File.basename(img[:source_folder]) : _sc[:name]) : File.basename(img[:source_folder]) %>
              <a href="<%= _sc ? "/collection/#{_sc[:id]}#row-#{img[:id]}" : "/catalog?show_all=1&folder=#{CGI.escape(img[:source_folder])}#row-#{img[:id]}" %>"
                 class="folder-name" title="View in collection"><%= hl_field(_col_name, hl[:collection_name]) %></a>
              <span class="file-name"><%= img[:filename] %></span>
            </div>



            <table class="result-meta">
              <tr>
                <th>Name</th>
                <td><%= hl_field(img[:mini_name], hl[:mini_name]) %></td>
              </tr>
              <tr>
                <th>Species</th>
                <td><%= hl_field(img[:species], hl[:species]) %></td>
              </tr>
              <tr>
                <th>Gender</th>
                <td><%= hl_field(img[:gender], hl[:gender]) %></td>
              </tr>
              <tr>
                <th>Weapons</th>
                <th>Armour</th>
                <td><%= hl_field(img[:weapons], hl[:weapons]) %></td>
                <td><%= hl_field(img[:armour], hl[:armour]) %></td>
              </tr>
              <tr>
                <th>Stance</th>
                <td><%= hl_field(img[:stance], hl[:stance]) %></td>
              </tr>
              <tr>
                <th>Size</th>
                <td><%= hl_field(img[:mini_size], hl[:mini_size]) %></td>
              </tr>
              <% if (img[:mini_count] || 1) > 1 %>
              <tr>
                <th>⬡ Minis</th>
                <td><span class="count-badge"><%= img[:mini_count] %></span></td>
              </tr>
              <% end %>
              <% if (img[:printed] || 0) > 0 %>
              <tr>
                <th>🖨</th>
                <td><span class="count-badge"><%= img[:printed] %> printed</span></td>
              </tr>
              <% end %>
              <% if (img[:painted] || 0) > 0 %>
              <tr>
                <th>🎨</th>
                <td><span class="count-badge count-badge-painted"><%= img[:painted] %> painted</span></td>
              </tr>
              <% end %>
              <% if img[:description].to_s.strip.length > 0 %>
              <tr>
                <th>Desc</th>
                <td class="desc-cell"><%= hl_field(img[:description], hl[:description]) %></td>
              </tr>
              <% end %>
            </table>

            <% if hl.any? %>
              <div class="match-tags">
                <% hl.each do |field, terms| %>
                  <% terms.each do |t| %>
                    <span class="match-tag <%= t.start_with?('~') ? 'match-fuzzy' : 'match-exact' %>">
                      <%= field %> · <%= t %>
                    </span>
                  <% end %>
                <% end %>
              </div>
            <% end %>

            <div class="result-actions">
              <a href="/edit/<%= img[:id] %>" class="btn-edit-sm">Edit ✎</a>
              <a href="<%= _sc ? "/collection/#{_sc[:id]}#row-#{img[:id]}" : "/catalog?show_all=1&folder=#{CGI.escape(img[:source_folder])}#row-#{img[:id]}" %>"
                 class="btn-edit-sm" title="View in collection: <%= File.basename(img[:source_folder]) %>">
                <%= File.basename(img[:source_folder]) %> →
              </a>
              <div class="colorized-btns" id="colorized-<%= img[:id] %>">
                <% col = img[:colorized] %>
                <button onclick="setColorized(<%= img[:id] %>, 'true',  this)"
                        class="btn-col-set <%= col == true  ? 'btn-col-active' : '' %>"
                        title="Mark as colorized render">🎨</button>
                <button onclick="setColorized(<%= img[:id] %>, 'false', this)"
                        class="btn-col-set <%= col == false ? 'btn-col-active' : '' %>"
                        title="Mark as grey/uncolored">⬜</button>
                <button onclick="setColorized(<%= img[:id] %>, 'null',  this)"
                        class="btn-col-set <%= col.nil?     ? 'btn-col-active' : '' %>"
                        title="Mark as unknown">❓</button>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if @query_made && @results.any? %>
<script>
var _scoreTimer = null;

function filterByScore(min) {
  min = parseFloat(min);
  // Update label immediately so slider feels responsive
  document.getElementById('score-value').textContent = min.toFixed(1);
  // Debounce the actual DOM filtering
  clearTimeout(_scoreTimer);
  _scoreTimer = setTimeout(function() {
    let cards = document.querySelectorAll('.result-card');
    let visible = 0;
    // Batch visibility changes to avoid repeated reflows
    let show = [], hide = [];
    cards.forEach(function(card) {
      parseFloat(card.dataset.score) >= min ? show.push(card) : hide.push(card);
    });
    hide.forEach(function(c) { c.style.display = 'none'; });
    show.forEach(function(c) { c.style.display = ''; });
    visible = show.length;
    let total = cards.length;
    document.getElementById('results-count').textContent =
      visible === total
        ? total + ' result' + (total === 1 ? '' : 's')
        : visible + ' of ' + total + ' result' + (total === 1 ? '' : 's');
  }, 180);
}
// Apply default threshold on load (no debounce needed on init)
(function() {
  let cards = document.querySelectorAll('.result-card');
  cards.forEach(function(c) {
    if (parseFloat(c.dataset.score) < 0.9) c.style.display = 'none';
  });
  let visible = document.querySelectorAll('.result-card:not([style*="none"])').length;
  let total = cards.length;
  if (visible < total) {
    document.getElementById('results-count').textContent =
      visible + ' of ' + total + ' result' + (total === 1 ? '' : 's');
  }
})();
</script>
<% end %>

<!-- Lightbox -->
<div id="lightbox" class="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <img id="lightbox-img" src="" alt="Preview">
</div>
