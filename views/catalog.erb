<%
  base_params = {}
  base_params[:folder]      = @folder_filter  unless @folder_filter.empty?
  base_params[:show_all]    = '1'             if @show_all && !@f_unprinted && !@f_unpainted
  base_params[:f_untagged]  = '1'             if @f_untagged
  base_params[:f_unprinted] = '1'             if @f_unprinted
  base_params[:f_unpainted] = '1'             if @f_unpainted
%>
<div class="page-header">
  <div>
    <h1>Image Catalog</h1>
    <p class="page-sub">
      <% if @total_unfiltered && @total_unfiltered != @total %>
        <strong><%= @total %></strong> filtered / <%= @total_unfiltered %> <%= @total_context %>
      <% elsif @total_unfiltered %>
        <%= @total %> <%= @total_context %>
      <% else %>
        <%= @total %> image<%= @total == 1 ? '' : 's' %>
      <% end %>
      <% if @f_untagged || @f_unprinted || @f_unpainted %>
        &nbsp;·&nbsp; <a href="/catalog?<%= q(base_params.reject{|k,_| [:f_untagged,:f_unprinted,:f_unpainted].include?(k)}) %>">Clear filters</a>
      <% end %>
      <% unless @folder_filter.empty? %>
        &nbsp;·&nbsp; <a href="/catalog?<%= q(base_params.reject{|k,_| k == :folder}) %>">All folders</a>
      <% end %>
      <% if @show_all && @status_filter.empty? && @folder_filter.empty? %>
        &nbsp;·&nbsp; <a href="/catalog?<%= q(base_params.reject{|k,_| k == :show_all}) %>">Show untagged only</a>
      <% elsif @status_filter.empty? && @folder_filter.empty? %>
        &nbsp;·&nbsp; <a href="/catalog?<%= q(base_params.merge(show_all: '1')) %>">Show all</a>
      <% end %>
    </p>
  </div>
  <div class="toolbar-right">

    <%# ── Status flag toggles ── %>
    <div class="status-filter-pills">
      <span class="status-pills-label">Filter:</span>
      <%
        flags = [
          [:f_untagged,  '○ Untagged',  @f_untagged],
          [:f_unprinted, '🖨 Unprinted', @f_unprinted],
          [:f_unpainted, '🎨 Unpainted', @f_unpainted],
        ]
        flags.each do |key, label, active|
          toggled = base_params.dup
          if active
            toggled.delete(key)  # toggle off
          else
            toggled[key] = '1'   # toggle on
          end
      %>
        <a href="/catalog?<%= q(toggled) %>"
           class="status-pill <%= active ? 'status-pill-active' : '' %>">
          <%= label %>
        </a>
      <% end %>
      <% if @f_untagged || @f_unprinted || @f_unpainted %>
        <a href="/catalog?<%= q(base_params.reject{|k,_| [:f_untagged,:f_unprinted,:f_unpainted].include?(k)}) %>"
           class="status-pill-clear">✕ clear</a>
      <% end %>
    </div>

    <%# ── Folder filter dropdown ── %>
    <form action="/catalog" method="get" class="folder-filter-form">
      <input type="hidden" name="show_all"    value="<%= @show_all ? '1' : '0' %>">
      <input type="hidden" name="f_untagged"  value="<%= @f_untagged  ? '1' : '' %>">
      <input type="hidden" name="f_unprinted" value="<%= @f_unprinted ? '1' : '' %>">
      <input type="hidden" name="f_unpainted" value="<%= @f_unpainted ? '1' : '' %>">
      <input type="hidden" name="f_untagged"  value="<%= @f_untagged  ? '1' : '' %>">
      <input type="hidden" name="f_unprinted" value="<%= @f_unprinted ? '1' : '' %>">
      <input type="hidden" name="f_unpainted" value="<%= @f_unpainted ? '1' : '' %>">
      <select name="folder" class="folder-select" onchange="this.form.submit()">
        <option value="">All folders</option>
        <% @folders.each do |f| %>
          <option value="<%= f %>" <%= @folder_filter == f ? 'selected' : '' %>>
            <%= File.basename(f) %>
          </option>
        <% end %>
      </select>
      <% unless @folder_filter.empty? %>
        <a href="/catalog<%= @show_all ? '?show_all=1' : '' %>" class="clear-filter" title="Clear filter">✕</a>
      <% end %>
    </form>

    <div class="thumb-sizer" title="Thumbnail size">
      <button class="size-btn" onclick="setThumbSize(60)"  data-size="60">S</button>
      <button class="size-btn" onclick="setThumbSize(120)" data-size="120">M</button>
      <button class="size-btn" onclick="setThumbSize(240)" data-size="240">L</button>
      <button class="size-btn" onclick="setThumbSize(320)" data-size="320">XL</button>
    </div>
    <% if @total == 0 && !@show_all %>
      <span class="badge badge-ok">✓ All tagged</span>
    <% end %>
  </div>
</div>

<%# ── Collection info bar (shown when filtered to one folder) ── %>
<% if !@folder_filter.empty? %>
  <% active_col = @collections.values.find { |c| c[:folder_path] == @folder_filter } %>
  <div class="collection-info-bar">
    <div class="collection-info-left">
      <svg viewBox="0 0 24 24" class="col-info-icon"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
      <span class="col-info-folder"><%= File.basename(@folder_filter) %></span>
      <% if active_col %>
        <form action="/collections/<%= active_col[:id] %>/rename" method="post" class="col-info-name-form" id="col-name-form">
          <input type="hidden" name="redirect_to" value="<%= request.url %>">
          <input type="text" name="name" value="<%= active_col[:name] %>"
                 class="col-info-name-input"
                 placeholder="collection name…"
                 id="col-name-input"
                 title="Click to edit collection name">
          <button type="submit" class="col-info-name-save" id="col-name-save" style="display:none" title="Save name">✓</button>
        </form>
      <% end %>
      <% if active_col && active_col[:release_month] %>
        <span class="col-info-month"><%= active_col[:release_month] %></span>
      <% end %>
    </div>
    <div class="col-info-actions">
      <% if active_col %>
        <a href="/collections#col-<%= active_col[:id] %>" class="col-info-edit">
          Edit collection ✎
        </a>
      <% end %>
      <% col_year = @folder_filter[/\d{4}/] %>
      <% if col_year %>
        <a href="/collections?year=<%= col_year %>" class="col-info-year">
          <%= col_year %> collections
        </a>
      <% end %>
      <% pdf = collection_pdf_path(@folder_filter) %>
      <% if pdf && active_col %>
        <a href="<%= pdf_url(active_col[:id]) %>" class="col-info-pdf" target="_blank" title="<%= @folder_filter %>.pdf">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Open PDF
        </a>
      <% end %>
    </div>
  </div>
<% end %>

<% if @images.empty? %>
  <div class="empty-state">
    <p>No images found. Use <strong>Scan Folder</strong> to discover images.</p>
  </div>
<% else %>

<div class="catalog-table-wrap">
  <table class="catalog-table" id="catalog-table">
    <colgroup>
      <col class="col-thumb">
      <col class="col-folder">
      <col class="col-file">
      <col class="col-name">
      <col class="col-species">
      <col class="col-gender">
      <col class="col-weapons">
      <col class="col-stance">
      <col class="col-size">
      <col class="col-count">
      <col class="col-actions">
    </colgroup>
    <thead>
      <tr>
        <th>Preview</th>
        <th>Folder</th>
        <th>File</th>
        <th>Name(s)</th>
        <th>Species</th>
        <th>Gender</th>
        <th>Weapons</th>
        <th class="cell-stance">Stance</th>
        <th>Size</th>
        <th title="Minis in image / Printed / Painted">🖨</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% last_col_id = nil %>
      <% @images.each do |img| %>

        <%# ── Collection header row (only when not filtered to one folder) ── %>
        <% if @folder_filter.empty? && img[:collection_id] != last_col_id %>
          <% last_col_id = img[:collection_id] %>
          <% col = @collections[img[:collection_id]] %>
          <tr class="collection-header-row">
            <td colspan="11">
              <span class="col-header-name">
                <%= col ? (col[:name].to_s.empty? ? '(unnamed collection)' : col[:name]) : File.basename(img[:source_folder]) %>
              </span>
              <% if col && col[:release_month] %>
                <span class="col-header-month"><%= col[:release_month] %></span>
              <% end %>
              <a href="/collections#col-<%= col ? col[:id] : '' %>" class="col-header-edit">edit collection ✎</a>
            </td>
          </tr>
        <% end %>

        <%# ── Image row ── %>
        <% is_secondary = !img[:primary_image_id].nil? %>
        <tr class="img-row <%= img[:tagged] ? 'row-tagged' : 'row-untagged' %> <%= is_secondary ? 'row-is-secondary' : '' %>" data-id="<%= img[:id] %>" id="row-<%= img[:id] %>">
          <form action="/images/<%= img[:id] %>" method="post" onsubmit="console.log('[xref-client-debug] is_secondary checkbox:', this.querySelector('input[name=is_secondary]')?.checked, 'primary_image_id:', this.querySelector('select[name=primary_image_id]')?.value)">
          <input type="hidden" name="folder"      value="<%= @folder_filter %>">
          <input type="hidden" name="show_all"    value="<%= @show_all ? '1' : '0' %>">
          <input type="hidden" name="f_untagged"  value="<%= @f_untagged  ? '1' : '' %>">
          <input type="hidden" name="f_unprinted" value="<%= @f_unprinted ? '1' : '' %>">
          <input type="hidden" name="f_unpainted" value="<%= @f_unpainted ? '1' : '' %>">
          <input type="hidden" name="f_untagged"  value="<%= @f_untagged  ? '1' : '' %>">
      <input type="hidden" name="f_unprinted" value="<%= @f_unprinted ? '1' : '' %>">
      <input type="hidden" name="f_unpainted" value="<%= @f_unpainted ? '1' : '' %>">
          <td class="cell-thumb">
            <div class="thumb-wrap">
              <img
                src="/image_file/<%= img[:id] %>"
                alt="<%= img[:filename] %>"
                loading="lazy"
                class="thumb"
                onclick="openLightbox(this.src)"
              >
              <% if img[:tagged] %><span class="tag-dot" title="Tagged — metadata has been saved for this image">✓</span><% end %>
              <% if img[:collection_id] %>
                <button type="button"
                        class="btn-set-cover"
                        title="Set as collection cover image"
                        onclick="setCover(<%= img[:collection_id] %>, <%= img[:id] %>, this)">⊙</button>
              <% end %>
            </div>
          </td>
          <td class="cell-folder">
            <a href="/catalog?folder=<%= CGI.escape(img[:source_folder]) %><%= @show_all ? '&show_all=1' : '' %>"
               class="folder-link" title="<%= img[:source_folder] %>">
              <%= File.basename(img[:source_folder]) %>
            </a>
          </td>
          <td class="cell-file">
            <span class="file-name"><%= img[:filename] %></span>
            <% if img[:image_size] %><span class="img-size-badge"><%= img[:image_size] %></span><% end %>
            <textarea name="description" class="cell-input cell-desc-inline"
                      rows="2"
                      placeholder="description…"><%= img[:description] %></textarea>
          </td>
          <td class="cell-name-td">
            <input type="text" name="mini_name" class="cell-input"
                   value="<%= img[:mini_name] %>"
                   id="name-input-<%= img[:id] %>"
                   style="<%= is_secondary ? 'display:none;' : '' %>">
            <% if img[:suggested_name].to_s.strip.length > 0 && img[:mini_name].to_s.strip.empty? %>
              <button type="button" class="btn-suggestion"
                      style="<%= is_secondary ? 'display:none;' : '' %>"
                      onclick="useSuggestion(<%= img[:id] %>, '<%= img[:suggested_name].gsub("'", "\\'") %>')">
                ✦ <%= img[:suggested_name] %>
              </button>
            <% end %>
            <span class="secondary-name-hidden" title="Linked images don't need their own name" style="<%= is_secondary ? '' : 'display:none;' %>">—</span>
          </td>
          <td>
            <input type="text" name="species" class="cell-input" value="<%= img[:species] %>"
                   style="<%= is_secondary ? 'display:none;' : '' %>">
          </td>
          <td>
            <select name="gender" class="cell-select" style="<%= is_secondary ? 'display:none;' : '' %>">
              <option value="">—</option>
              <% ['M','F','NA','M,F','M,NA','F,NA','M,F,NA'].each do |g| %>
                <option value="<%= g %>" <%= img[:gender] == g ? 'selected' : '' %>><%= g %></option>
              <% end %>
            </select>
          </td>
          <td><input type="text" name="weapons"   class="cell-input" value="<%= img[:weapons] %>"></td>
          <td class="cell-stance"><input type="text" name="stance" class="cell-input" value="<%= img[:stance] %>"></td>
          <td>
            <select name="mini_size" class="cell-select">
              <option value="">—</option>
              <% ['S','M','L','S,M','M,L','S,M,L'].each do |s| %>
                <option value="<%= s %>" <%= img[:mini_size] == s ? 'selected' : '' %>><%= s %></option>
              <% end %>
            </select>
          </td>
          <td class="cell-count">
            <div class="count-stack">
              <div class="count-row" title="Minis in image">
                <span class="count-icon">⬡</span>
                <select name="mini_count" class="count-mini-select" title="Number of minis in this image">
                  <% [1,2,3,'4+'].each do |n| %>
                    <% cur = (img[:mini_count] || 1) %>
                    <% selected = (n == '4+' ? cur >= 4 : cur == n) ? 'selected' : '' %>
                    <option value="<%= n %>" <%= selected %>><%= n %></option>
                  <% end %>
                </select>
              </div>
              <div class="count-row" title="Printed" style="<%= is_secondary ? 'display:none;' : '' %>">
                <span class="count-icon count-printed">🖨</span>
                <select name="printed" class="count-mini-select">
                  <% (0..10).each do |n| %>
                    <option value="<%= n %>" <%= (img[:printed] || 0) == n ? 'selected' : '' %>><%= n %></option>
                  <% end %>
                </select>
              </div>
              <div class="count-row" title="Painted" style="<%= is_secondary ? 'display:none;' : '' %>">
                <span class="count-icon count-painted">🎨</span>
                <select name="painted" class="count-mini-select">
                  <% (0..10).each do |n| %>
                    <option value="<%= n %>" <%= (img[:painted] || 0) == n ? 'selected' : '' %>><%= n %></option>
                  <% end %>
                </select>
              </div>
              <div class="secondary-of" title="This image is a secondary view linked to a primary image" style="<%= is_secondary ? '' : 'display:none;' %>">
                ↳ <%= @primary_lookup[img[:primary_image_id]].to_s.empty? ? "(primary ##{img[:primary_image_id]})" : @primary_lookup[img[:primary_image_id]] %>
              </div>

              <%# ── Cross-reference: link this image as a secondary view ── %>
              <div class="count-row xref-row">
                <label class="xref-label" title="Mark this image as an alternate view of another image in this collection">
                  <input type="checkbox" name="is_secondary" value="1"
                         class="xref-checkbox"
                         <%= is_secondary ? 'checked' : '' %>
                         onchange="toggleXrefSelect(<%= img[:id] %>, this.checked)">
                  <span class="xref-icon">🔗</span>
                </label>
                <select name="primary_image_id" id="xref-select-<%= img[:id] %>"
                        class="count-mini-select xref-select">
                  <option value="">— pick image —</option>
                  <% (@collection_images[img[:collection_id]] || []).each do |other| %>
                    <% next if other[:id] == img[:id] %>
                    <% label = other[:mini_name].to_s.empty? ? other[:filename] : other[:mini_name] %>
                    <option value="<%= other[:id] %>" <%= img[:primary_image_id] == other[:id] ? 'selected' : '' %>>
                      <%= label %>
                    </option>
                  <% end %>
                </select>
              </div>
            </div>
          </td>
          <td class="cell-actions">
            <button type="submit" class="btn-save" title="Save">✓</button>
            <a href="/edit/<%= img[:id] %>" class="btn-edit" title="Full edit">✎</a>
          </td>
          </form>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pages > 1 %>
  <div class="pagination">
    <% flag_str = "#{@f_untagged ? 'f_untagged=1&' : ''}#{@f_unprinted ? 'f_unprinted=1&' : ''}#{@f_unpainted ? 'f_unpainted=1&' : ''}" %>
  <% base = "/catalog?#{@show_all ? 'show_all=1&' : ''}#{@folder_filter.empty? ? '' : "folder=#{CGI.escape(@folder_filter)}&"}#{flag_str}" %>
    <% if @page > 1 %>
      <a href="<%= base %>page=<%= @page - 1 %>" class="page-btn">← Prev</a>
    <% end %>
    <span class="page-info">Page <%= @page %> of <%= @pages %></span>
    <% if @page < @pages %>
      <a href="<%= base %>page=<%= @page + 1 %>" class="page-btn">Next →</a>
    <% end %>
  </div>
<% end %>

<% end %>

<div id="lightbox" class="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <img id="lightbox-img" src="" alt="Preview">
</div>

<script>
(function() {
  const saved = localStorage.getItem('thumbSize');
  if (saved) applyThumbSize(parseInt(saved), false);
})();

function setThumbSize(px) {
  localStorage.setItem('thumbSize', px);
  applyThumbSize(px, true);
}

function applyThumbSize(px, animate) {
  document.querySelectorAll('.thumb').forEach(t => {
    if (animate) t.style.transition = 'width 0.2s, height 0.2s';
    t.style.width  = px + 'px';
    t.style.height = px + 'px';
  });
  const col = document.querySelector('.col-thumb');
  if (col) col.style.width = (px + 12) + 'px';
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.classList.toggle('size-btn-active', parseInt(btn.dataset.size) === px);
  });
}

function useSuggestion(id, name) {
  const input = document.getElementById('name-input-' + id);
  if (input) {
    input.value = name;
    input.dispatchEvent(new Event('input'));
    input.focus();
    const btn = input.closest('td').querySelector('.btn-suggestion');
    if (btn) btn.style.display = 'none';
  }
}
</script>
