<div class="page-header">
  <div>
    <h1>Statistics</h1>
    <p class="page-sub"><%= @total_images %> images · <%= @total_collections %> collections</p>
  </div>
</div>

<div class="stats-grid">

  <%# ── Overview ── %>
  <div class="stats-card">
    <h2 class="stats-title">Overview</h2>
    <div class="stats-row-group">
      <div class="stats-row">
        <a href="/catalog?show_all=1" class="stats-label stats-link">Total images</a>
        <span class="stats-value"><%= @total_images %></span>
      </div>
      <div class="stats-row">
        <a href="/collections" class="stats-label stats-link">Collections</a>
        <span class="stats-value"><%= @total_collections %></span>
      </div>
    </div>
  </div>

  <%# ── Tagged ── %>
  <div class="stats-card">
    <h2 class="stats-title">Tagged</h2>
    <div class="stats-row-group">
      <div class="stats-row">
        <a href="/catalog?show_all=1" class="stats-label stats-link">Tagged</a>
        <span class="stats-value"><%= @total_tagged %> <span class="stats-pct">(<%= @total_images > 0 ? (@total_tagged * 100 / @total_images) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/catalog" class="stats-label stats-link stats-warn">Untagged</a>
        <span class="stats-value stats-warn"><%= @total_untagged %> <span class="stats-pct">(<%= @total_images > 0 ? (@total_untagged * 100 / @total_images) : 0 %>%)</span></span>
      </div>
    </div>
  </div>

  <%# ── Colorized ── %>
  <div class="stats-card">
    <h2 class="stats-title">Colorized</h2>
    <div class="stats-row-group">
      <div class="stats-row">
        <a href="/catalog?show_all=1&colorized=true" class="stats-label stats-link">🎨 Colorized</a>
        <span class="stats-value"><%= @colorized_color %> <span class="stats-pct">(<%= @total_images > 0 ? (@colorized_color * 100 / @total_images) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/catalog?show_all=1&colorized=false" class="stats-label stats-link">⬜ Grey</a>
        <span class="stats-value"><%= @colorized_grey %> <span class="stats-pct">(<%= @total_images > 0 ? (@colorized_grey * 100 / @total_images) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/bulk?field=colorized" class="stats-label stats-link stats-warn">❓ Unknown</a>
        <span class="stats-value stats-warn"><%= @colorized_unknown %> <span class="stats-pct">(<%= @total_images > 0 ? (@colorized_unknown * 100 / @total_images) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/catalog?show_all=1&colorized=true" class="stats-label stats-link <%= @unlinked_colorized > 0 ? 'stats-warn' : '' %>">🔗 Unlinked colorized</a>
        <span class="stats-value <%= @unlinked_colorized > 0 ? 'stats-warn' : '' %>"><%= @unlinked_colorized %></span>
      </div>
    </div>
  </div>

  <%# ── Printed ── %>
  <div class="stats-card">
    <h2 class="stats-title">🖨 Printed</h2>
    <p class="stats-note">Excludes bundles &amp; secondaries (<%= @total_trackable %> trackable)</p>
    <div class="stats-row-group">
      <div class="stats-row">
        <a href="/catalog?show_all=1&f_unprinted=0" class="stats-label stats-link">Any printed</a>
        <span class="stats-value"><%= @total_printed %> <span class="stats-pct">(<%= @total_trackable > 0 ? (@total_printed * 100 / @total_trackable) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/catalog?show_all=1&f_unprinted=1" class="stats-label stats-link stats-warn">Unprinted</a>
        <span class="stats-value stats-warn"><%= @total_unprinted %> <span class="stats-pct">(<%= @total_trackable > 0 ? (@total_unprinted * 100 / @total_trackable) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">Total copies</span>
        <span class="stats-value stats-accent"><%= @sum_printed %></span>
      </div>
    </div>
  </div>

  <%# ── Painted ── %>
  <div class="stats-card">
    <h2 class="stats-title">🎨 Painted</h2>
    <p class="stats-note">Excludes bundles &amp; secondaries (<%= @total_trackable %> trackable)</p>
    <div class="stats-row-group">
      <div class="stats-row">
        <a href="/catalog?show_all=1&f_unpainted=0" class="stats-label stats-link">Any painted</a>
        <span class="stats-value"><%= @total_painted %> <span class="stats-pct">(<%= @total_trackable > 0 ? (@total_painted * 100 / @total_trackable) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <a href="/catalog?show_all=1&f_unpainted=1" class="stats-label stats-link stats-warn">Unpainted</a>
        <span class="stats-value stats-warn"><%= @total_unpainted %> <span class="stats-pct">(<%= @total_trackable > 0 ? (@total_unpainted * 100 / @total_trackable) : 0 %>%)</span></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">Total copies</span>
        <span class="stats-value stats-accent"><%= @sum_painted %></span>
      </div>
    </div>
  </div>

  <%# ── Species ── %>
  <div class="stats-card stats-card-wide">
    <h2 class="stats-title">Species</h2>
    <% if @by_species.empty? %>
      <p class="stats-empty">No species data yet</p>
    <% else %>
      <table class="stats-table sortable-stats" data-sort="count">
        <thead><tr>
          <th class="sort-col" onclick="sortStatsTable(this, 'alpha')" title="Sort alphabetically">Species ↕</th>
          <th onclick="sortStatsTable(this, 'count')" title="Sort by count"># ↕</th>
        </tr></thead>
        <tbody>
          <% @by_species.each do |s, count| %>
            <tr>
              <td><a href="/search?species=<%= CGI.escape(s) %>" class="stats-link"><%= s %></a></td>
              <td><%= count %></td>
              <td class="stats-pct"><%= @total_images > 0 ? (count * 100 / @total_images) : 0 %>%</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <%# ── Gender ── %>
  <div class="stats-card">
    <h2 class="stats-title">Gender</h2>
    <div class="stats-row-group">
      <% @by_gender.each do |g, count| %>
        <div class="stats-row">
          <a href="/search?gender=<%= CGI.escape(g) %>" class="stats-label stats-link"><%= g %></a>
          <span class="stats-value"><%= count %></span>
        </div>
      <% end %>
      <% if @by_gender.empty? %><p class="stats-empty">No gender data yet</p><% end %>
    </div>
  </div>

  <%# ── Size ── %>
  <div class="stats-card">
    <h2 class="stats-title">Mini Size</h2>
    <% if @by_size.empty? %>
      <p class="stats-empty">No size data yet</p>
    <% else %>
      <table class="stats-table sortable-stats" id="size-table" data-sort="numeric">
        <thead><tr>
          <th class="sort-col" onclick="sortSizeTable(this)" title="Sort alphabetically">Size ↕</th>
          <th onclick="sortSizeTableByCount(this)" title="Sort by count"># ↕</th>
        </tr></thead>
        <tbody>
          <% @by_size.each do |s, count| %>
            <tr data-mm="<%= s.to_s.scan(/\d+/).first.to_i %>">
              <td><a href="/search?mini_size=<%= CGI.escape(s) %>" class="stats-link"><%= s %></a></td>
              <td><%= count %></td>
              <td class="stats-pct"><%= @total_images > 0 ? (count * 100 / @total_images) : 0 %>%</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <%# ── Weapons ── %>
  <div class="stats-card stats-card-wide">
    <h2 class="stats-title">Weapons</h2>
    <% if @by_weapons.empty? %>
      <p class="stats-empty">No weapons data yet</p>
    <% else %>
      <table class="stats-table sortable-stats" data-sort="count">
        <thead><tr>
          <th class="sort-col" onclick="sortStatsTable(this, 'alpha')" title="Sort alphabetically">Weapon ↕</th>
          <th onclick="sortStatsTable(this, 'count')" title="Sort by count"># ↕</th>
        </tr></thead>
        <tbody>
          <% @by_weapons.each do |w, count| %>
            <tr>
              <td><a href="/search?weapons=<%= CGI.escape(w) %>" class="stats-link"><%= w %></a></td>
              <td><%= count %></td>
              <td class="stats-pct"><%= @total_images > 0 ? (count * 100 / @total_images) : 0 %>%</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <%# ── Stance ── %>
  <div class="stats-card stats-card-wide">
    <h2 class="stats-title">Stances</h2>
    <% if @by_stance.empty? %>
      <p class="stats-empty">No stance data yet</p>
    <% else %>
      <table class="stats-table sortable-stats" data-sort="count">
        <thead><tr>
          <th class="sort-col" onclick="sortStatsTable(this, 'alpha')" title="Sort alphabetically">Stance ↕</th>
          <th onclick="sortStatsTable(this, 'count')" title="Sort by count"># ↕</th>
        </tr></thead>
        <tbody>
          <% @by_stance.each do |s, count| %>
            <tr>
              <td><a href="/search?stance=<%= CGI.escape(s) %>" class="stats-link"><%= s %></a></td>
              <td><%= count %></td>
              <td class="stats-pct"><%= @total_images > 0 ? (count * 100 / @total_images) : 0 %>%</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
</div><%# close stats-grid %>

<% if @field_coverage&.any? %>
<div class="stats-grid">
  <div class="stats-card stats-card-wide">
    <h2 class="stats-title">Field Coverage</h2>
    <p class="stats-note">Tagged images · excl. bundles &amp; secondaries (<%= @field_coverage.first&.dig(:total) || 0 %> images)</p>
    <table class="stats-table">
      <thead>
        <tr><th>Field</th><th>Filled</th><th>Total</th><th>Coverage</th><th>%</th></tr>
      </thead>
      <tbody>
        <% @field_coverage.each do |f| %>
          <% bar_w = f[:pct].round %>
          <% color = f[:pct] < 25 ? '#ef4444' : f[:pct] < 60 ? '#f59e0b' : '#22c55e' %>
          <tr>
            <td class="stats-folder"><%= f[:field] %></td>
            <td style="text-align:right;"><%= f[:filled] %></td>
            <td style="text-align:right; color:var(--text-faint);"><%= f[:total] %></td>
            <td>
              <div style="background:var(--bg3); border-radius:4px; height:8px; overflow:hidden; min-width:120px;">
                <div style="width:<%= bar_w %>%; height:100%; background:<%= color %>; border-radius:4px; transition:width 0.3s;"></div>
              </div>
            </td>
            <td class="stats-pct" style="color:<%= color %>; text-align:right;"><%= f[:pct] %>%</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>

<script>
function sortSizeTable(th) {
  var table = document.getElementById('size-table');
  var tbody = table.querySelector('tbody');
  var rows  = Array.from(tbody.querySelectorAll('tr'));
  var currentMode = table.dataset.sort;
  var newMode = currentMode === 'numeric' ? 'alpha' : 'numeric';
  table.dataset.sort = newMode;
  rows.sort(function(a, b) {
    if (newMode === 'numeric') {
      return parseInt(a.dataset.mm || 0) - parseInt(b.dataset.mm || 0);
    } else {
      return a.cells[0].textContent.trim().localeCompare(b.cells[0].textContent.trim());
    }
  });
  rows.forEach(function(r) { tbody.appendChild(r); });
  table.querySelectorAll('th').forEach(function(h) { h.classList.remove('sort-active'); });
  th.classList.add('sort-active');
}

function sortSizeTableByCount(th) {
  var table = document.getElementById('size-table');
  var tbody = table.querySelector('tbody');
  var rows  = Array.from(tbody.querySelectorAll('tr'));
  table.dataset.sort = 'count';
  rows.sort(function(a, b) {
    return parseInt(b.cells[1].textContent.trim()) - parseInt(a.cells[1].textContent.trim());
  });
  rows.forEach(function(r) { tbody.appendChild(r); });
  table.querySelectorAll('th').forEach(function(h) { h.classList.remove('sort-active'); });
  th.classList.add('sort-active');
}

function sortStatsTable(th, mode) {
  var table = th.closest('table');
  var tbody = table.querySelector('tbody');
  var rows  = Array.from(tbody.querySelectorAll('tr'));
  var currentMode = table.dataset.sort;
  // Toggle: if already this mode, flip between count and alpha
  var newMode = (currentMode === mode) ? (mode === 'count' ? 'alpha' : 'count') : mode;
  table.dataset.sort = newMode;

  rows.sort(function(a, b) {
    if (newMode === 'alpha') {
      var at = a.cells[0].textContent.trim();
      var bt = b.cells[0].textContent.trim();
      return at.localeCompare(bt);
    } else {
      var an = parseInt(a.cells[1].textContent.trim()) || 0;
      var bn = parseInt(b.cells[1].textContent.trim()) || 0;
      return bn - an;
    }
  });

  rows.forEach(function(r) { tbody.appendChild(r); });

  // Update all th indicators
  table.querySelectorAll('th').forEach(function(h) {
    h.classList.remove('sort-active');
  });
  th.classList.add('sort-active');
}
</script>
