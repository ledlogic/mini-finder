<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UNIT9 Miniatures Catalog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@300;400;600;800&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="sidenav">
    <div class="sidenav-brand">
      <span class="brand-unit">UNIT</span><span class="brand-9">9</span>
      <span class="brand-sub">CATALOG</span>
    </div>
    <form action="/scan" method="post" class="scan-form">
      <button type="submit" class="btn-scan">
        <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Scan Folder
      </button>
    </form>
    <ul class="nav-links">
      <li><a href="/catalog" class="<%= request.path_info.start_with?('/catalog') || request.path_info == '/' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h10"/></svg>
        Catalog
      </a></li>
      <li><a href="/collections" class="<%= request.path_info.start_with?('/collections') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M3 7h18M3 12h18M3 17h12"/><circle cx="19" cy="17" r="2"/></svg>
        Collections
      </a></li>
      <li><a href="/search" class="<%= request.path_info == '/search' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        Search
      </a></li>
      <li><a href="/random" class="<%= request.path_info == '/random' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="1.5"/><circle cx="18" cy="6" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="6" cy="18" r="1.5"/><circle cx="18" cy="18" r="1.5"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
        Random
      </a></li>
    </ul>
    <div class="sidenav-footer">
      <code class="root-path"><%= settings.root_folder %></code>
      <% db_path = File.join(settings.root, 'db', 'catalog.db') %>
      <% db_size = File.exist?(db_path) ? File.size(db_path) : 0 %>
      <% db_human = if db_size > 1_048_576
           "%.1f MB" % (db_size / 1_048_576.0)
         elsif db_size > 1_024
           "%.1f KB" % (db_size / 1_024.0)
         else
           "#{db_size} B"
         end %>
      <span class="db-size" title="<%= db_path %>">
        <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        <%= db_human %>
      </span>
      <% changes = session[:changes_since_backup].to_i %>
      <% remind  = changes >= 25 %>
      <form action="/backup" method="post" class="backup-form">
        <button type="submit" class="btn-backup <%= remind ? 'btn-backup-warn' : '' %>"
                title="<%= remind ? "#{changes} changes since last backup — back up now!" : "Back up database (#{changes} changes since last backup)" %>">
          <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <% if remind %>
            Backup (<%= changes %>!)
          <% else %>
            Backup
          <% end %>
        </button>
      </form>
    </div>
  </nav>

  <main class="main-content">
    <% if params[:backed_up] %>
      <div class="toast toast-backup">
        💾 Backup saved: <code><%= params[:backed_up] %></code>
      </div>
    <% end %>
    <% if params[:scanned] %>
      <div class="toast">
        ✓ Found <strong><%= params[:scanned] %></strong> new image<%= params[:scanned].to_i == 1 ? '' : 's' %>
        <% if params[:purged].to_i > 0 %>
          &nbsp;·&nbsp; removed <strong><%= params[:purged] %></strong> missing folder<%= params[:purged].to_i == 1 ? '' : 's' %>
        <% end %>
        <% if params[:new_col].to_i > 0 %>
          &nbsp;·&nbsp; <a href="/collections#col-<%= params[:new_col] %>" class="toast-link">View new collection →</a>
        <% end %>
      </div>
    <% end %>
    <%= yield %>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
