<div class="page-header">
  <div>
    <h1>Edit Image</h1>
    <p class="page-sub"><%= @image[:source_folder] %> / <strong><%= @image[:filename] %></strong></p>
  </div>
  <a href="/catalog" class="btn-back">← Back to Catalog</a>
</div>

<div class="edit-layout">
  <div class="edit-image-panel">
    <img src="/image_file/<%= @image[:id] %>" alt="<%= @image[:filename] %>" class="edit-image">
    <div class="edit-meta-info">
      <% if @image[:image_size] %>
        <span class="meta-chip">📐 <%= @image[:image_size] %></span>
      <% end %>
      <% _edit_col = Collections.where(folder_path: @image[:source_folder]).first %>
      <% if _edit_col %>
        <a href="/collection/<%= _edit_col[:id] %>#row-<%= @image[:id] %>" class="meta-chip meta-chip-link" title="Go to collection">🗂 <%= File.basename(@image[:source_folder]) %></a>
      <% else %>
        <span class="meta-chip">🗂 <%= File.basename(@image[:source_folder]) %></span>
      <% end %>
      <span class="meta-chip status-<%= @image[:tagged] ? 'tagged' : 'untagged' %>">
        <%= @image[:tagged] ? '✓ Tagged' : '○ Untagged' %>
      </span>
    </div>
  </div>

  <div class="edit-form-panel">
    <form action="/edit/<%= @image[:id] %>" method="post" class="edit-form">

      <div class="form-group">
        <label>Mini Name(s) <span class="hint">comma-separated for multiple</span></label>
        <div class="edit-name-row">
          <input type="text" name="mini_name" id="edit-mini-name"
                 value="<%= @image[:mini_name] %>"
                 placeholder="e.g. Zara, Rex, The Watcher" autofocus>
          <button type="button" class="btn-detect" id="btn-detect-name"
                  onclick="detectEditName(<%= @image[:id] %>)"
                  title="Scan image for name text">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Detect
          </button>
        </div>
        <div id="edit-detect-result" class="col-detect-result" style="margin-top:6px;"></div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Species <span class="hint">comma-separated</span></label>
          <input type="text" name="species" id="edit-species" value="<%= @image[:species] %>" placeholder="e.g. Human, Elf, Orc" autocomplete="off">
          <% if @top_species&.any? %>
            <div class="species-quickpick" style="margin-top:6px;">
              <% @top_species.each do |sp| %>
                <button type="button"
                        class="btn-quickpick <%= @image[:species].to_s.split(',').map(&:strip).map(&:upcase).include?(sp) ? 'btn-quickpick-active' : '' %>"
                        data-target="edit-species" data-value="<%= sp %>"
                        onclick="editQuickpick(this)"><%= sp %></button>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="form-group">
          <label>Gender</label>
          <div class="multi-check">
            <% ['M','F','NA'].each do |g| %>
              <label class="check-label">
                <input type="checkbox" name="gender_<%= g %>" value="<%= g %>"
                  <%= @image[:gender].to_s.split(',').map(&:strip).include?(g) ? 'checked' : '' %>
                  onchange="syncGenderField()">
                <%= g %>
              </label>
            <% end %>
          </div>
          <input type="hidden" name="gender" id="gender-hidden" value="<%= @image[:gender] %>">
        </div>
      </div>

      <div class="form-group">
        <label>Weapons <span class="hint">comma-separated</span></label>
        <input type="text" name="weapons" id="edit-weapons" value="<%= @image[:weapons] %>" class="cell-input-upper" placeholder="e.g. Sword, Pistol, Staff" autocomplete="off">
        <% if @top_weapons&.any? && @image[:weapons].to_s.strip.empty? %>
          <div class="species-quickpick" style="margin-top:6px;">
            <% @top_weapons.each do |wp| %>
              <button type="button"
                      class="btn-quickpick <%= @image[:weapons].to_s.split(',').map(&:strip).map(&:upcase).include?(wp) ? 'btn-quickpick-active' : '' %>"
                      data-target="edit-weapons" data-value="<%= wp %>"
                      onclick="editQuickpick(this)"><%= wp %></button>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Stance <span class="hint">comma-separated</span></label>
          <input type="text" name="stance" id="edit-stance" value="<%= @image[:stance] %>" placeholder="e.g. Combat, Resting, Charging" autocomplete="off">
          <% if @top_stance&.any? && @image[:stance].to_s.strip.empty? %>
            <div class="species-quickpick" style="margin-top:6px;">
              <% @top_stance.each do |st| %>
                <button type="button"
                        class="btn-quickpick <%= @image[:stance].to_s.split(',').map(&:strip).map(&:upcase).include?(st) ? 'btn-quickpick-active' : '' %>"
                        data-target="edit-stance" data-value="<%= st %>"
                        onclick="editQuickpick(this)"><%= st %></button>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="form-group">
          <label>Mini Count <span class="hint">number of minis shown</span></label>
          <select name="mini_count" class="cell-select">
            <% [1,2,3,'4+'].each do |n| %>
              <% cur = (@image[:mini_count] || 1) %>
              <% selected = (n == '4+' ? cur >= 4 : cur == n) ? 'selected' : '' %>
              <option value="<%= n %>" <%= selected %>><%= n %> mini<%= n == 1 ? '' : 's' %></option>
            <% end %>
          </select>
        </div>
        <% is_secondary = !@image[:primary_image_id].nil? %>
        <div class="form-group" id="print-paint-group" style="<%= is_secondary ? 'opacity:0.35;' : '' %>">
          <label>🖨 Printed</label>
          <select name="printed" class="cell-select" <%= is_secondary ? 'disabled' : '' %>>
            <% (0..10).each do |n| %>
              <option value="<%= n %>" <%= (@image[:printed] || 0) == n ? 'selected' : '' %>><%= n %></option>
            <% end %>
          </select>
        </div>
        <div class="form-group" id="print-paint-group-2" style="<%= is_secondary ? 'opacity:0.35;' : '' %>">
          <label>🎨 Painted</label>
          <select name="painted" class="cell-select" <%= is_secondary ? 'disabled' : '' %>>
            <% (0..10).each do |n| %>
              <option value="<%= n %>" <%= (@image[:painted] || 0) == n ? 'selected' : '' %>><%= n %></option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="xref-label-edit">
            <input type="checkbox" name="is_secondary" value="1"
                   id="edit-is-secondary"
                   <%= is_secondary ? 'checked' : '' %>
                   onchange="toggleEditXref(this.checked)">
            🔗 This image is an alternate view of another image in this collection
          </label>
          <select name="primary_image_id" id="edit-xref-select" class="cell-select"
                  <%= is_secondary ? '' : 'disabled' %>>
            <option value="">— pick image —</option>
            <% @collection_images.each do |other| %>
              <% next if other[:id] == @image[:id] %>
              <% base  = other[:mini_name].to_s.empty? ? other[:filename] : other[:mini_name] %>
              <% extra = [other[:stance], other[:weapons]].map(&:to_s).reject(&:empty?).join(', ') %>
              <% label = extra.empty? ? base : "#{base} (#{extra})" %>
              <option value="<%= other[:id] %>" <%= @image[:primary_image_id] == other[:id] ? 'selected' : '' %>>
                <%= label %>
              </option>
            <% end %>
          </select>
          <% if @primary_name %>
            <p class="hint">Currently linked to: <strong><%= @primary_name %></strong></p>
          <% end %>
        </div>
      </div>

      <script>
        function toggleEditXref(checked) {
          const select = document.getElementById('edit-xref-select');
          const printed = document.querySelector('#print-paint-group select');
          const painted = document.querySelector('#print-paint-group-2 select');
          select.disabled = !checked;
          if (!checked) select.value = '';
          [printed, painted].forEach(s => s.disabled = checked);
          document.getElementById('print-paint-group').style.opacity   = checked ? '0.35' : '';
          document.getElementById('print-paint-group-2').style.opacity = checked ? '0.35' : '';
        }
      </script>

      <div class="form-row">
        <div class="form-group">
          <label>Size</label>
          <div class="multi-check">
            <label class="check-label">
              <input type="radio" name="mini_size" value="" <%= @image[:mini_size].to_s.empty? ? 'checked' : '' %>>
              —
            </label>
            <% ['10mm','20mm','30mm','40mm','50mm','60mm','75mm','80mm','100mm'].each do |s| %>
              <label class="check-label">
                <input type="radio" name="mini_size" value="<%= s %>"
                  <%= @image[:mini_size].to_s.strip == s ? 'checked' : '' %>>
                <%= s %>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>Description <span class="hint">free text · Levenshtein searchable</span></label>
        <textarea name="description" rows="3" placeholder="e.g. Female cyborg warrior with katana, crouching on rooftop. Red LED eyes. Detailed armour plating."><%= @image[:description] %></textarea>
      </div>

      

<script>
async function detectEditName(id) {
  const btn    = document.getElementById('btn-detect-name');
  const result = document.getElementById('edit-detect-result');
  const input  = document.getElementById('edit-mini-name');
  btn.disabled = true;
  btn.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg> Scanning…';
  result.innerHTML = '';

  try {
    const res  = await fetch(`/images/${id}/detect_name`);
    const data = await res.json();

    if (!res.ok) {
      result.innerHTML = `<span class="detect-error">✕ ${data.error}</span>`;
      return;
    }

    let html = '';
    if (data.suggested_name)
      html += `<span class="detect-chip detect-mini" onclick="useEditDetected('edit-mini-name', '${data.suggested_name.replace(/'/g,"\'")}', this)">✦ ${data.suggested_name}</span>`;
    if (data.collection_name)
      html += `<span class="detect-chip detect-col" onclick="useEditDetected('edit-mini-name', '${data.collection_name.replace(/'/g,"\'")}', this)">⊕ ${data.collection_name}</span>`;
    if (!html)
      html = '<span class="detect-error">No text found</span>';

    result.innerHTML = '<span class="detect-label">Click to use: </span>' + html;
  } catch(e) {
    result.innerHTML = '<span class="detect-error">✕ Request failed</span>';
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg> Detect';
  }
}

function useEditDetected(inputId, value, chip) {
  const input = document.getElementById(inputId);
  if (!input) return;
  input.value = value;
  document.querySelectorAll('#edit-detect-result .detect-chip').forEach(c => c.classList.remove('detect-chip-active'));
  chip.classList.add('detect-chip-active');
}

function syncGenderField() {
  const vals = ['M','F','NA'].filter(v => document.querySelector(`input[name=gender_${v}]`).checked);
  document.getElementById('gender-hidden').value = vals.join(',');
}

</script>
