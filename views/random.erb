<div class="page-header">
  <div>
    <h1>Random</h1>
    <p class="page-sub"><%= @images.length %> of <%= @count %> images</p>
  </div>
  <div style="display:flex; align-items:center; gap:14px;">
    <div class="thumb-sizer" title="Card size">
      <button class="size-btn" onclick="setRandomSize(40)" data-size="40">XS</button>
      <button class="size-btn" onclick="setRandomSize(60)" data-size="60">S</button>
      <button class="size-btn" onclick="setRandomSize(100)" data-size="100">M</button>
      <button class="size-btn" onclick="setRandomSize(160)" data-size="160">L</button>
      <button class="size-btn" onclick="setRandomSize(240)" data-size="240">XL</button>
      <button class="size-btn" onclick="setRandomSize(360)" data-size="360">XXL</button>
    </div>
    <a href="<%= url_random %>" class="btn-scan" style="text-decoration:none;">
      <svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="1.5"/><circle cx="18" cy="6" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="6" cy="18" r="1.5"/><circle cx="18" cy="18" r="1.5"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
      Shuffle
    </a>
  </div>
</div>

<div class="col-year-bar" style="margin-bottom:10px;">
  <span class="bulk-label">Color:</span>
  <% [['', 'All'], ['true', '🎨 Color'], ['false', '⬜ Grey'], ['unknown', '◌ Unknown']].each do |val, label| %>
    <a href="<%= url_random(colorized: val) %>"
       class="col-year-btn <%= @colorized_filter == val ? 'col-year-active' : '' %>">
      <%= label %>
    </a>
  <% end %>
</div>
<div class="col-year-bar" style="margin-bottom:10px;">
  <span class="bulk-label">Show:</span>
  <a href="<%= url_random(no_bundles: !@no_bundles) %>"
     class="col-year-btn <%= @no_bundles ? 'col-year-active' : '' %>">
    🚫 Bundles
  </a>
  <a href="<%= url_random(no_vehicles: !@no_vehicles) %>"
     class="col-year-btn <%= @no_vehicles ? 'col-year-active' : '' %>">
    🚫 Vehicles
  </a>
  <a href="<%= url_random(unprinted: !@unprinted_only) %>"
     class="col-year-btn <%= @unprinted_only ? 'col-year-active' : '' %>">
    🖨 Unprinted only
  </a>
</div>
<div class="col-year-bar" style="margin-bottom:18px;">
  <span class="bulk-label">Count:</span>
  <% [10, 20, 30, 60, 90, 120, 180, 240].each do |n| %>
    <a href="<%= url_random(n: n) %>"
       class="col-year-btn <%= @random_count == n ? 'col-year-active' : '' %>">
      <%= n %>
    </a>
  <% end %>
</div>

<% if @images.empty? %>
  <div class="empty-state">No images in the catalog yet. Scan a folder first.</div>
<% else %>
  <div class="results-grid" id="random-grid">
    <% @images.each do |img| %>
      <% col_link = img[:folder_path] ?
           (img[:collection_id] ? "/collection/#{img[:collection_id]}?page=#{img[:target_page]}#row-#{img[:id]}" : "/catalog?show_all=1&folder=#{CGI.escape(img[:folder_path].to_s)}&page=#{img[:target_page]}#row-#{img[:id]}") :
           nil %>
      <div class="result-card">
        <% if col_link %>
          <a href="<%= col_link %>" class="result-image-wrap">
            <img src="/image_file/<%= img[:id] %>" alt="<%= img[:filename] %>" loading="lazy" class="result-image">
          </a>
        <% else %>
          <div class="result-image-wrap" onclick="openLightbox('/image_file/<%= img[:id] %>')">
            <img src="/image_file/<%= img[:id] %>" alt="<%= img[:filename] %>" loading="lazy" class="result-image">
          </div>
        <% end %>
        <div class="result-body">
          <div class="result-file">
            <span class="file-name"><%= img[:mini_name].to_s.empty? ? img[:filename] : img[:mini_name] %></span>
          </div>
          <% if col_link %>
            <a href="<%= col_link %>" class="folder-name" style="display:block; margin-top:4px;">
              <%= img[:collection_name].to_s.empty? ? File.basename(img[:folder_path].to_s) : img[:collection_name] %>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<script>
(function() {
  const saved = localStorage.getItem('randomCardSize');
  if (saved) applyRandomSize(parseInt(saved), false);
})();

function setRandomSize(px) {
  document.querySelectorAll('.random-img').forEach(img => {
    img.style.width = px + 'px'; img.style.height = px + 'px';
  });
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.classList.toggle('size-btn-active', parseInt(btn.dataset.size) === px);
  });
  try { localStorage.setItem('mf_thumb_size', px); } catch(e) {}
}

function applyRandomSize(px, animate) {
  const grid = document.getElementById('random-grid');
  if (grid) {
    if (animate) grid.style.transition = 'grid-template-columns 0.2s';
    grid.style.gridTemplateColumns = `repeat(auto-fill, minmax(${px}px, 1fr))`;
  }
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.classList.toggle('size-btn-active', parseInt(btn.dataset.size) === px);
  });
}
</script>
